# CS Beverly Hills — EVOKE Marketplace Integration
# Copy this file to .env to override the built-in defaults.

# Base URL for the EVOKE Marketplace API (no trailing slash, must end in /api).
# Defaults to the shared EVOKE backend when unset. Blank it out to force
# offline/mock mode.
VITE_EVOKE_API_BASE=https://ltxkr9vk-3000.inc1.devtunnels.ms/api

# EVOKE API key (sent as x-api-key header) — optional.
VITE_EVOKE_API_KEY=

# Public EVOKE site URL
VITE_EVOKE_SITE_URL=https://www.evokemarketplace.com

# Exact StoreName of CS Beverly Hills on EVOKE (case-insensitive match).
VITE_CSBH_STORE_NAME=CS Beverly Hills

# Legacy slug (kept for reference; the API matches by store NAME above).
VITE_CSBH_STORE_SLUG=cs-beverly-hills

# Optional: comma-separated VendorID(s) — only needed to scope the global
# best-seller / new-collection endpoints down to this store.
VITE_CSBH_VENDOR_IDS=

# EVOKE cart and checkout redirect URLs
VITE_EVOKE_CART_URL=https://www.evokemarketplace.com/mainCart
VITE_EVOKE_CHECKOUT_URL=https://www.evokemarketplace.com/checkout

# Name of the auth cookie EVOKE sets on the same domain
VITE_EVOKE_AUTH_COOKIE_NAME=evoke_user
